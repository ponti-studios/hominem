{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "workspaces": {
    "apps/web": {
      "entry": ["app/**/*.{ts,tsx}"],
      "project": ["app/**/*.{ts,tsx}"]
    },

    "apps/mobile": {
      "entry": ["app/**/*.{ts,tsx}", "e2e/**/*.{js,ts}"],
      "project": ["**/*.{ts,tsx}"]
    },

    "services/api": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "packages/core/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "packages/platform/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "packages/platform/utils": {
      "project": ["*.ts"]
    },

    "packages/domains/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "tools/*": {
      "entry": ["src/cli.ts", "src/**/*.ts", "*.ts", "*.mts", "vitest.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },

  "ignoreDependencies": ["tsx", "turbo"],

  "ignoreUnresolved": ["^vite/client$"],

  "ignoreFiles": ["apps/mobile/tests/support/**"],

  "ignore": [
  ],

  "ignoreIssues": {
    "apps/mobile/tests/support/**": ["exports"]
  }
}
