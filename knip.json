{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "workspaces": {
    "apps/web": {
      "entry": ["app/**/*.{ts,tsx}"],
      "project": ["app/**/*.{ts,tsx}"]
    },

    "apps/mobile": {
      "entry": ["app/**/*.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },

    "services/api": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "packages/core/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "packages/platform/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "packages/domains/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "tools/*": {
      "entry": ["src/cli.ts", "src/**/*.ts", "*.ts", "*.mts", "vitest.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },

  "ignoreDependencies": ["babel-preset-expo"],

  "ignoreBinaries": [],

  "ignoreUnresolved": ["^vite/client$"],

  "ignore": [
    "packages/platform/ui/src/components/**",
    "apps/mobile/components/**",
    "apps/mobile/services/**",
    "apps/mobile/hooks/**",
    "apps/mobile/types/**",
    "apps/mobile/modules/**"
  ]
}
