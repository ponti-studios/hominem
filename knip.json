{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "workspaces": {
    "apps/omiro": {
      "entry": ["app/**/*.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },

    "services/api": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "packages/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "tools/*": {
      "entry": ["src/cli.ts", "src/**/*.ts", "*.ts", "*.mts", "vitest.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },

  "ignoreDependencies": ["babel-preset-expo"],

  "ignoreBinaries": [],

  "ignoreUnresolved": ["^vite/client$"],

  "ignore": [
    "packages/ui/src/components/**",
    "apps/omiro/components/**",
    "apps/omiro/services/**",
    "apps/omiro/hooks/**",
    "apps/omiro/types/**",
    "apps/omiro/modules/**"
  ]
}
