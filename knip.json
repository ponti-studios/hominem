{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.{ts,js,mjs,cjs}",
        "scripts/**/*.{ts,js,mjs,cjs}"
      ],
      "project": [
        "scripts/**/*.{ts,tsx,js,jsx,mjs,cjs}"
      ],
      "ignore": [
        "apps/**",
        "packages/**",
        "services/**",
        "tools/**"
      ]
    },

    "apps/web": {
      "entry": [
        "app/root.tsx",
        "app/routes.ts",
        "app/env.d.ts",
        "react-router.config.ts",
        "vite.config.ts",
        "vitest.config.ts",
        "playwright.config.ts"
      ],
      "project": [
        "app/**/*.{ts,tsx}"
      ]
    },

    "apps/mobile": {
      "entry": [
        "app/**/*.{ts,tsx}",
        "app.config.ts",
        "babel.config.js",
        "metro.config.js",
        "react-native.config.js",
        "vitest.config.ts",
        "e2e/**/*.{js,ts}"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "config/**/*.{ts,tsx}",
        "hooks/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "plugins/**/*.{ts,tsx}",
        "theme/**/*.{ts,tsx}",
        "utils/**/*.{ts,tsx}"
      ]
    },

    "apps/desktop": {
      "entry": [
        "src/main/index.ts",
        "src/preload/index.ts",
        "src/renderer/src/main.tsx",
        "electron.vite.config.ts",
        "vite.config.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },

    "services/api": {
      "entry": [
        "src/index.ts",
        "src/server.ts",
        "vitest.config.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },

    "services/workers": {
      "entry": [
        "src/index.ts",
        "vitest.config.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },

    "packages/*": {
      "entry": [
        "src/index.ts",
        "src/index.tsx",
        "*.config.{ts,js,mjs,cjs}",
        "vitest.config.ts",
        "vite.config.ts",
        "postcss.config.{ts,js,mjs,cjs}",
        "tailwind.config.{ts,js,mjs,cjs}"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },

    "tools/*": {
      "entry": [
        "src/cli.ts",
        "src/**/*.ts",
        "*.ts",
        "*.mts",
        "vitest.config.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    }
  },

  "ignore": [
    "**/build/**",
    "**/dist/**",
    "**/.turbo/**",
    "**/.cache/**",
    "**/coverage/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/test-assets/**"
  ]
}
