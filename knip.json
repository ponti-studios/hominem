{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "workspaces": {
    "apps/omiro": {
      "entry": ["app/**/*.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },

    "apps/career": {
      "project": ["app/**/*.{ts,tsx}"]
    },

    "services/api": {
      "entry": ["src/index.ts", "src/worker.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },

    "packages/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },

    "tools/*": {
      "entry": ["src/cli.ts", "src/**/*.ts", "*.ts", "*.mts", "vitest.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },

  "ignoreDependencies": [
    "babel-preset-expo",
    "tw-animate-css",
    "tailwindcss",
    "expo-updates",
    "@expo/plist",
    "@expo/image-utils",
    "@expo/prebuild-config"
  ],

  "ignoreBinaries": [],

  "ignoreUnresolved": ["^vite/client$"],

  "ignore": [
    "packages/ui/src/components/**",
    "apps/omiro/components/**",
    "apps/omiro/services/**",
    "apps/omiro/modules/**"
  ]
}
