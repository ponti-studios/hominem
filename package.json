{
  "name": "hominem",
  "version": "1.0.0",
  "private": true,
  "description": "hominem",
  "keywords": [],
  "homepage": "https://github.com/hackefeller/hominem#readme",
  "bugs": {
    "url": "https://github.com/hackefeller/hominem/issues"
  },
  "license": "ISC",
  "author": {
    "name": "chase bridges",
    "email": "code@hominem.io",
    "url": "https://ponti.io/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackefeller/hominem.git"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "tools/*",
    "packages/core/*",
    "packages/platform/*",
    "packages/domains/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo dev",
    "dev:web": "bun run dev --filter @hominem/api --filter @hominem/web",
    "format": "turbo run format",
    "knip": "knip --include files,dependencies,exports --isolate-workspaces --no-config-hints",
    "knip:fix": "knip --fix",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "update:turbo": "bunx @turbo/codemod@latest update"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@typescript/native-preview": "7.0.0-dev.20260319.1",
    "@vitest/coverage-v8": "^4.0.18",
    "knip": "^5.86.0",
    "oxfmt": "0.37.0",
    "oxlint": "1.52.0",
    "turbo": "^2.8.20",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "overrides": {
    "@hono/zod-validator": "0.7.6",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.1.7",
    "lucide-react": "0.576.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "tailwind-merge": "^3.2.0",
    "vite": "8.0.0",
    "zod": "4.3.6"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.0"
}
