{
  "name": "@hominem/finance",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "pnpm exec oxlint ./app",
    "lint:fix": "pnpm exec oxlint ./app --fix",
    "format": "pnpm exec oxfmt ./app --write",
    "format:check": "pnpm exec oxfmt ./app --check",
    "build": "react-router build",
    "clean": "rm -rf build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "tsc --noEmit",
    "typegen": "react-router typegen",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hominem/api": "workspace:*",
    "@hominem/auth": "workspace:*",
    "@hominem/env": "workspace:*",
    "@hominem/queues": "workspace:*",
    "@hominem/rpc": "workspace:*",
    "@hominem/ui": "workspace:*",
    "@hominem/utils": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@react-router/node": "8.2.0",
    "@react-router/serve": "8.2.0",
    "@tanstack/react-query": "5.100.10",
    "clsx": "^2.1.1",
    "date-fns": "4.4.0",
    "hono": "4.12.25",
    "isbot": "^5",
    "lucide-react": "1.24.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-plaid-link": "4.1.1",
    "react-router": "8.2.0",
    "recharts": "3.9.2",
    "tailwind-merge": "^3.0.1",
    "workbox-window": "^7.4.0",
    "zod": "catalog:",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@react-router/dev": "8.2.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "29.1.1",
    "rollup-plugin-visualizer": "7.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "4.1.0"
  }
}
