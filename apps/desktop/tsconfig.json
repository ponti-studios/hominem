{
  "extends": "../../tsconfig.profiles/vite-app.json",
  "compilerOptions": {
    "composite": false,
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@hominem/*": [
        "../../packages/core/*",
        "../../packages/platform/*",
        "../../packages/domains/*",
        "../../services/*"
      ]
    },
    "types": [
      "node",
      "vite/client"
    ],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "../../.cache/app-desktop.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "electron.vite.config.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist",
    "release",
    ".turbo",
    ".cache",
    "coverage"
  ]
}
