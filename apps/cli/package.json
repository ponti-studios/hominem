{
  "name": "@hominem/cli",
  "version": "1.0.0",
  "description": "Unified CLI for hominem tools",
  "bin": {
    "hominem": "bin/hominem.js"
  },
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run src/**/*.test.ts --passWithNoTests",
    "lint": "oxlint --tsconfig tsconfig.json \"src/**/*.{ts,tsx,js,jsx}\"",
    "format": "oxfmt src"
  },
  "dependencies": {
    "@oclif/core": "^4.0.19",
    "chalk": "^5.4.1",
    "consola": "^3.4.2",
    "keytar": "^7.9.0",
    "open": "^10.1.1",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^25.4.0",
    "dotenv": "^16.4.7",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.16"
  },
  "oclif": {
    "bin": "hominem",
    "commands": "dist/commands",
    "dirname": "hominem",
    "plugins": [],
    "topicSeparator": " "
  }
}
