{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "24.14.1",
      "pnpm": "11.10.0",
      "env": {
        "SENTRY_ORG": "ponti-studios",
        "SENTRY_PROJECT": "omiro"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "APP_ENV": "development"
      }
    },
    "e2e": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "APP_ENV": "e2e"
      }
    },
    "staging": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "internal",
      "environment": "preview",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "staging"
      },
      "channel": "staging"
    },
    "screenshots": {
      "extends": "staging",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:4040",
        "APP_ENV": "staging"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_ON_DEVICE_AI_SPIKE_ENABLED": "true"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760221796"
      }
    }
  }
}
