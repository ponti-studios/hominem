{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "24.14.1",
      "corepack": true,
      "env": {
        "EXPO_RUNTIME_VERSION": "ios-r1"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_RUNTIME_VERSION": "ios-r1",
        "APP_ENV": "development",
        "EXPO_PUBLIC_E2E_TESTING": "false",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "e2e": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "EXPO_RUNTIME_VERSION": "ios-r1",
        "APP_ENV": "development",
        "EXPO_PUBLIC_E2E_TESTING": "true",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
        ,
        "OMIRO_DEV_CLIENT": "false"
      }
    },
    "staging": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_RUNTIME_VERSION": "ios-r1",
        "APP_ENV": "production",
        "EXPO_PUBLIC_E2E_TESTING": "false",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "true",
        "OMIRO_DEV_CLIENT": "false",
        "OMIRO_RELEASE_CHANNEL": "staging"
      },
      "channel": "staging"
    },
    "screenshots": {
      "extends": "staging",
      "env": {
        "EXPO_RUNTIME_VERSION": "ios-r1",
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:4040",
        "EXPO_PUBLIC_E2E_TESTING": "false",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "true",
        "OMIRO_DEV_CLIENT": "false",
        "OMIRO_RELEASE_CHANNEL": "staging"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_RUNTIME_VERSION": "ios-r1",
        "APP_ENV": "production",
        "EXPO_PUBLIC_E2E_TESTING": "false",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "true",
        "OMIRO_DEV_CLIENT": "false",
        "OMIRO_RELEASE_CHANNEL": "production"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760221796"
      }
    }
  }
}
