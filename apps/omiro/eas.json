{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.13.0"
    },
    "dev": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "e2e": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "e2e",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "preview": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      },
      "channel": "preview"
    },
    "screenshots": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:4040",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      },
      "ios": {
        "simulator": true
      },
      "channel": "preview"
    },
    "production": {
      "extends": "base",
      "developmentClient": false,
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "true"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760221796"
      }
    }
  }
}
