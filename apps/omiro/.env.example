# Copy this file to .env.development.local
# Note: EXPO_PUBLIC_* values are embedded into the client app bundle.

APP_ENV="development"
EXPO_RUNTIME_VERSION="ios-r1"
EXPO_PUBLIC_API_BASE_URL="http://localhost:4040"
EXPO_PUBLIC_E2E_AUTH_SECRET="<e2e-auth-secret>"
EXPO_PUBLIC_E2E_TESTING="false"
EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED="false"
# Domain hosting apple-app-site-association for native passkeys (must match
# services/api's AUTH_PASSKEY_RP_ID). Leave unset for local dev against
# http://localhost — associated domains require a real HTTPS host.
EXPO_PUBLIC_AUTH_PASSKEY_RP_ID=""
EXPO_PUBLIC_POSTHOG_API_KEY="<posthog-public-key>"
EXPO_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
EXPO_PUBLIC_SENTRY_DSN="<sentry-public-dsn>"
OMIRO_DEV_CLIENT="true"
