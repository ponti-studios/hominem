    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nitro-image",
          "omiro-intents",
          "voice-transcriber",
          "on-device-ai"
