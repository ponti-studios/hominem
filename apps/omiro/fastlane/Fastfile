default_platform(:ios)

platform :ios do
  private_lane :connect_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch('ASC_KEY_ID'),
      issuer_id: ENV.fetch('ASC_ISSUER_ID'),
      key_content: ENV.fetch('ASC_KEY_CONTENT'),
      is_key_content_base64: true,
    )
  end

  desc 'Assign the latest EAS build to the internal TestFlight group'
  lane :testflight do
    pilot(
      api_key: connect_api_key,
      app_identifier: ENV.fetch('ASC_BUNDLE_ID', 'com.pontistudios.hakumi'),
      distribute_external: false,
      skip_submission: true,
      skip_waiting_for_build_processing: false,
      groups: ENV['TESTFLIGHT_GROUP'].to_s.empty? ? nil : [ENV['TESTFLIGHT_GROUP']],
    )
  end

  desc 'Submit the already-uploaded build and version to App Review'
  lane :submit_for_review do
    options = {
      api_key: connect_api_key,
      app_identifier: ENV.fetch('ASC_BUNDLE_ID', 'com.pontistudios.hakumi'),
      skip_binary_upload: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: false,
      phased_release: true,
      force: true,
    }
    options[:app_version] = ENV['APP_VERSION'] if ENV['APP_VERSION']
    deliver(options)
  end

  desc 'Release the approved version with phased release enabled'
  lane :release do
    options = {
      api_key: connect_api_key,
      app_identifier: ENV.fetch('ASC_BUNDLE_ID', 'com.pontistudios.hakumi'),
      skip_binary_upload: true,
      skip_metadata: true,
      automatic_release: true,
      phased_release: true,
      force: true,
    }
    options[:app_version] = ENV['APP_VERSION'] if ENV['APP_VERSION']
    deliver(options)
  end
end
