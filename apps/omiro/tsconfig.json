{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "../../.cache/app-omiro.tsbuildinfo",
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "expo-symbols": ["./node_modules/expo-symbols/build/index"],
      "@shopify/flash-list": ["./node_modules/@shopify/flash-list/dist/index"],
      "~/*": ["./*"]
    },
    "noEmit": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "modules/**/*.ts",
    "modules/**/*.tsx",
    "services/**/*.ts",
    "constants/**/*.ts",
    "tests/**/*.ts",
    "navigation/**/*.ts",
    "app.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    ".cache",
    ".expo/web",
    "ios",
    "android",
    "coverage",
    "*.tsbuildinfo"
  ]
}
