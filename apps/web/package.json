    "@hominem/hono-rpc": "workspace:*",
    "@hominem/invites-react": "workspace:*",
    "@hominem/lists-react": "workspace:*",
    "@hominem/places-react": "workspace:*",
    "@hominem/services": "workspace:*",
    "@hominem/ui": "workspace:*",
    "@hominem/utils": "workspace:*",
