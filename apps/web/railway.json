{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/apps/web/Dockerfile",
    "watchPatterns": [
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/turbo.json",
      "/apps/web/**",
      "/packages/**"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @hakumi/web run start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "sleepApplication": false,
    "region": "us-west2",
    "overlapSeconds": 30,
    "drainingSeconds": 30
  }
}
