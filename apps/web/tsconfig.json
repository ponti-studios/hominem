{
  "extends": "../../tsconfig.profiles/vite-app.json",
  "compilerOptions": {
    "rootDirs": [".", "./.react-router/types"],
    "tsBuildInfoFile": "../../.cache/app-web.tsbuildinfo",
    "paths": {
      "~/*": ["./app/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    ".react-router/types/**/*",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    ".turbo",
    ".cache",
    "coverage",
    ".react-router/cache",
    "*.tsbuildinfo"
  ]
}
