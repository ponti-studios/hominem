# Local API origin for the web app.
VITE_PUBLIC_API_URL=""

# PostHog (feature flags + analytics)
# Get your key at https://us.posthog.com/project/settings
VITE_POSTHOG_API_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# Browser telemetry
# Set VITE_OTEL_DISABLED=true to force telemetry off.
VITE_OTEL_DISABLED="false"
VITE_OTEL_SERVICE_NAME="hominem-web"
VITE_OTEL_SERVICE_VERSION="0.0.0"
VITE_OTEL_DEPLOYMENT_ENVIRONMENT="development"
VITE_OTEL_EXPORTER_OTLP_ENDPOINT="none"
VITE_OTEL_TRACES_SAMPLER_ARG="1.0"
