VITE_APP_BASE_URL=""
VITE_PUBLIC_API_URL=""

# Observability (OpenTelemetry)
# Sends telemetry to local stack at http://localhost:4318
# Start the stack: ~/.local/observability/observability.sh start
# View dashboards: http://localhost:3000 (admin/admin)
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
VITE_OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
VITE_OTEL_SERVICE_NAME=hominem-web
VITE_OTEL_DEPLOYMENT_ENVIRONMENT=development
VITE_OTEL_TRACES_SAMPLER_ARG=1.0

# Services
GOOGLE_API_KEY=""
OPENAI_API_KEY=""
TAVILY_API_KEY=""
GEOCODE_EARTH_API_KEY=""
