{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "../../.cache/app-mobile.tsbuildinfo",
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@hakumi/ui/badge": ["../../packages/platform/ui/src/components/ui/badge.native.tsx"],
      "@hakumi/ui/button": ["../../packages/platform/ui/src/components/ui/button.native.tsx"],
      "@hakumi/ui/chat": ["../../packages/platform/ui/src/components/chat/index.mobile.ts"],
      "@hakumi/ui/empty-state": [
        "../../packages/platform/ui/src/components/mobile/empty-state.native.tsx"
      ],
      "@hakumi/ui/list-row": [
        "../../packages/platform/ui/src/components/mobile/list-row.native.tsx"
      ],
      "@hakumi/ui/list-shell": [
        "../../packages/platform/ui/src/components/mobile/list-shell.native.tsx"
      ],
      "@hakumi/ui/page": ["../../packages/platform/ui/src/components/layout/page.native.tsx"],
      "@hakumi/ui/separator": [
        "../../packages/platform/ui/src/components/ui/separator.native.tsx"
      ],
      "@hakumi/ui/surface": [
        "../../packages/platform/ui/src/components/mobile/surface.native.tsx"
      ],
      "@hakumi/ui/text": ["../../packages/platform/ui/src/components/typography/text.native.tsx"],
      "@hakumi/ui/text-field": [
        "../../packages/platform/ui/src/components/ui/text-field.native.tsx"
      ],
      "expo-symbols": ["./node_modules/expo-symbols/build/index"],
      "@shopify/flash-list": ["./node_modules/@shopify/flash-list/dist/index"],
      "~/*": ["./*"]
    },
    "noEmit": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "modules/**/*.ts",
    "modules/**/*.tsx",
    "services/**/*.ts",
    "constants/**/*.ts",
    "tests/**/*.ts",
    "navigation/**/*.ts",
    "app.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    ".cache",
    ".expo/web",
    "ios",
    "android",
    "coverage",
    "*.tsbuildinfo"
  ]
}
