{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "../../.cache/app-mobile.tsbuildinfo",
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./*"
      ]
    },
    "noEmit": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "modules/**/*.ts",
    "modules/**/*.tsx",
    "services/**/*.ts",
    "constants/**/*.ts",
    "tests/**/*.ts",
    "navigation/**/*.ts",
    "app.config.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    ".cache",
    ".expo/web",
    "ios",
    "android",
    "coverage",
    "*.tsbuildinfo"
  ]
}
