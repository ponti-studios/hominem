{
  "cli": {
    "version": ">= 10.0.0",
    "packageManager": "pnpm",
    "appVersionSource": "remote"
  },
  "build": {
    "dev": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_APPLE_TEAM_ID": "$EXPO_APPLE_TEAM_ID",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "e2e": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "e2e",
        "EXPO_APPLE_TEAM_ID": "$EXPO_APPLE_TEAM_ID",
        "EXPO_PUBLIC_E2E_AUTH_SECRET": "$EXPO_PUBLIC_E2E_AUTH_SECRET",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_APPLE_TEAM_ID": "$EXPO_APPLE_TEAM_ID",
        "EXPO_PUBLIC_API_BASE_URL": "$API_BASE_URL",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      },
      "channel": "preview"
    },
    "production": {
      "developmentClient": false,
      "distribution": "store",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_APPLE_TEAM_ID": "$EXPO_APPLE_TEAM_ID",
        "EXPO_PUBLIC_API_BASE_URL": "$API_BASE_URL",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "true"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "$EXPO_APPLE_TEAM_ID"
      }
    }
  }
}
