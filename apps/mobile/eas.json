{
  "cli": {
    "version": ">= 10.0.3",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "APP_VARIANT": "dev"
      }
    },
    "e2e": {
      "channel": "e2e",
      "distribution": "internal",
      "developmentClient": false,
      "environment": "development",
      "env": {
        "APP_VARIANT": "e2e"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "store",
      "autoIncrement": true,
      "environment": "preview",
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "preview-simulator": {
      "channel": "preview",
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "APP_VARIANT": "preview"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "APP_VARIANT": "production"
      },
      "resourceClass": "large"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "3QHJ2KN8AL",
        "ascAppId": "6760221796"
      }
    },
    "development": {},
    "preview": {
      "ios": {
        "appleTeamId": "3QHJ2KN8AL"
      }
    }
  }
}
