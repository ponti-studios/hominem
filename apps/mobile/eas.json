{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "dev": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "e2e": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "e2e",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      },
      "channel": "preview"
    },
    "production": {
      "developmentClient": false,
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "true"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760221796"
      }
    }
  }
}
