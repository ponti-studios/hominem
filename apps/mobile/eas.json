{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "dev": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_APPLE_TEAM_ID": "3QHJ2KN8AL",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "e2e": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "e2e",
        "EXPO_APPLE_TEAM_ID": "3QHJ2KN8AL",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      }
    },
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.ponti.io",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      },
      "channel": "preview"
    },
    "production": {
      "developmentClient": false,
      "distribution": "store",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.ponti.io",
        "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED": "false"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "3QHJ2KN8AL"
      }
    }
  }
}
