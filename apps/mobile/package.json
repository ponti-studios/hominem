{
  "name": "@hominem/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "bash scripts/run-variant.sh dev expo start --dev-client",
    "check:expo-config": "bash scripts/check-expo-config.sh",
    "target": "bash scripts/dev-target.sh",
    "target:sim": "bash scripts/dev-target.sh simulator",
    "target:device": "bash scripts/dev-target.sh device",
    "web": "expo start --web",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "lint": "bunx tsx ./scripts/check-style-tokens.ts && bunx oxlint ./app ./components ./utils ./theme ./lib",
    "format": "bunx oxfmt ./app ./components ./utils ./theme ./lib",
    "test": "bun run test:auth:unit && bun run test:auth:integration",
    "test:auth:unit": "vitest run --config vitest.config.ts tests/auth-state-machine.test.ts tests/auth-route-guard.test.ts tests/startup-metrics.test.ts tests/auth-validation.test.ts tests/auth-boot.test.ts tests/auth-provider.test.tsx tests/screens/auth-screens.test.tsx tests/routes/auth-router.test.tsx",
    "test:auth:integration": "vitest run --config vitest.config.ts tests/integration/auth-contract.integration.test.ts tests/integration/auth-flow.integration.test.ts",
    "test:e2e:all": "detox test -c ios.sim.e2e --cleanup",
    "test:e2e:auth": "detox test -c ios.sim.e2e --testPathPattern=e2e/auth.mobile.e2e.js --cleanup --retries 0",
    "test:e2e:deep-links": "detox test -c ios.sim.e2e --testPathPattern=e2e/deep-links.mobile.e2e.js --cleanup --retries 0",
    "test:e2e:smoke": "detox test -c ios.sim.e2e --testPathPattern=e2e/smoke.mobile.e2e.js --cleanup",
    "test:e2e:smoke:ci": "detox test -c ios.sim.e2e --testPathPattern=e2e/smoke.mobile.e2e.js --cleanup --retries 0 --record-logs all --take-screenshots failing --record-videos failing --artifacts-location artifacts/detox-smoke",
    "test:e2e:build": "bash scripts/ensure-ios-variant.sh e2e && detox build -c ios.sim.e2e",
    "postinstall": "node node_modules/@shopify/react-native-skia/scripts/install-libs.js",
    "verify:eas-env:preview": "bash scripts/check-release-env.sh preview",
    "verify:eas-env:production": "bash scripts/check-release-env.sh production",
    "verify:eas-profiles": "bash scripts/check-eas-profiles.sh"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.2.12",
    "@bacons/apple-targets": "^4.0.6",
    "@better-auth/passkey": "^1.5.4",
    "@expo/vector-icons": "^15.0.3",
    "@hominem/auth": "workspace:*",
    "@hominem/chat-services": "workspace:*",
    "@hominem/env": "workspace:*",
    "@hominem/rpc": "workspace:*",
    "@hominem/services": "workspace:*",
    "@hominem/ui": "workspace:*",
    "@hominem/utils": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/drawer": "^7.0.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "^2.5.3",
    "@shopify/restyle": "^2.4.4",
    "@tanstack/react-query": "^5.60.5",
    "better-auth": "^1.4.19",
    "expo": "^55.0.8",
    "expo-application": "~55.0.10",
    "expo-asset": "~55.0.10",
    "expo-audio": "~55.0.9",
    "expo-background-task": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-calendar": "^55.0.10",
    "expo-camera": "^55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-device": "~55.0.10",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-haptics": "^55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.13",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-live-activity": "^0.4.2",
    "expo-local-authentication": "^55.0.9",
    "expo-localization": "~55.0.9",
    "expo-media-library": "^55.0.10",
    "expo-network": "~55.0.9",
    "expo-notifications": "~55.0.13",
    "expo-print": "^55.0.9",
    "expo-router": "~55.0.7",
    "expo-screen-capture": "^55.0.9",
    "expo-secure-store": "~55.0.9",
    "expo-sharing": "^55.0.14",
    "expo-speech": "^55.0.9",
    "expo-sqlite": "~55.0.11",
    "expo-store-review": "^55.0.9",
    "expo-symbols": "^55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-task-manager": "^55.0.10",
    "expo-updates": "~55.0.15",
    "expo-web-browser": "~55.0.10",
    "posthog-react-native": "^4.37.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-ios-context-menu": "3.2.1",
    "react-native-ios-utilities": "5.2.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "zeego": "3.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/runtime": "^7.28.6",
    "@better-auth/expo": "^1.4.19",
    "@jest/reporters": "^29.7.0",
    "@testing-library/react-native": "14.0.0-beta.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.1.7",
    "babel-preset-expo": "^55.0.10",
    "detox": "^20.27.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-expo": "~55.0.11",
    "test-renderer": "0.14.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "peerDependencies": {
    "react-native-svg": "15.15.3"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "packageManager": "bun@1.3.10",
  "expo": {
    "install": {
      "exclude": [
        "react-native-safe-area-context"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [],
        "listUnknownPackages": [
          "@biomejs/biome"
        ]
      }
    }
  },
  "trustedDependencies": [
    "@clerk/shared",
    "@parcel/watcher",
    "browser-tabs-lock",
    "core-js"
  ]
}
