{
  "name": "@hominem/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "bash scripts/run-variant.sh dev expo start --dev-client",
    "target": "bash scripts/dev-target.sh",
    "target:sim": "bash scripts/dev-target.sh simulator",
    "target:device": "bash scripts/dev-target.sh device",
    "typecheck": "tsc --noEmit",
    "lint": "bunx tsx ./scripts/check-style-tokens.ts && bunx oxlint ./app ./components ./utils ./theme ./lib",
    "format": "bunx oxfmt ./app ./components ./utils ./theme ./lib",
    "ios": "make ios",
    "prebuild": "make prebuild-dev",
    "prebuild:dev": "make prebuild-dev",
    "prebuild:e2e": "make prebuild-e2e",
    "build:development": "make build-dev",
    "build:e2e": "make build-e2e",
    "build:preview": "make build-preview",
    "build:production": "make build-production",
    "build:update:preview": "make update-preview",
    "build:update:preview:rollout:50": "make update-preview-50",
    "build:update:preview:rollout:100": "make update-preview-100",
    "build:update:preview:rollback": "make update-preview-rollback",
    "build:update:production": "make update-production",
    "web": "expo start --web",
    "test:e2e": "bun run test:e2e:auth:critical",
    "test:auth": "bun run test:unit:auth && bun run test:integration:auth && bun run test:screens:auth && bun run test:routes:auth && bun run test:e2e:auth:critical",
    "test:unit": "bun run test:unit:auth",
    "test:integration": "vitest run --config vitest.config.ts tests/integration/",
    "test:integration:auth": "vitest run --config vitest.config.ts tests/integration/auth-contract.integration.test.ts tests/integration/auth-flow.integration.test.ts",
    "test:routes:auth": "node ./node_modules/jest/bin/jest.js --config jest.route.config.cjs",
    "test:screens:auth": "node ./node_modules/jest/bin/jest.js --config jest.screen.config.cjs",
    "test": "bun run test:unit:auth && bunx vitest run --config vitest.config.ts tests/integration/*.integration.test.ts",
    "test:unit:auth": "vitest run --config vitest.config.ts tests/auth-state-machine.test.ts tests/auth-provider-utils.test.ts tests/auth-route-guard.test.ts tests/startup-metrics.test.ts tests/auth-validation.test.ts tests/auth-boot.test.ts",
    "test:e2e:build:ios": "bun run prebuild:e2e && detox build -c ios.sim.e2e",
    "test:e2e:auth:critical": "detox test -c ios.sim.e2e --testPathPattern=e2e/auth.mobile.e2e.js --cleanup --retries 0",
    "test:e2e:auth:mobile": "bun run test:e2e:auth:critical",
    "test:e2e:deep-links": "detox test -c ios.sim.e2e --testPathPattern=e2e/deep-links.mobile.e2e.js --cleanup --retries 0",
    "test:e2e:smoke": "detox test -c ios.sim.e2e --testPathPattern=e2e/smoke.mobile.e2e.js --cleanup",
    "android": "expo run:android"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.2.12",
    "@better-auth/passkey": "^1.5.4",
    "@expo/vector-icons": "^15.0.3",
    "@hominem/auth": "workspace:*",
    "@hominem/chat-services": "workspace:*",
    "@hominem/hono-client": "workspace:*",
    "@hominem/hono-rpc": "workspace:*",
    "@hominem/ui": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/drawer": "^7.0.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/restyle": "^2.4.4",
    "@tanstack/react-query": "^5.60.5",
    "better-auth": "^1.4.19",
    "expo": "~55.0.0",
    "expo-application": "~55.0.9",
    "expo-asset": "^55.0.8",
    "expo-audio": "^55.0.8",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "~55.0.0",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-dev-client": "~55.0.16",
    "expo-device": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.12",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-network": "~55.0.8",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-sqlite": "~55.0.10",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "~55.0.13",
    "expo-web-browser": "~55.0.9",
    "posthog-react-native": "^4.37.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-ios-context-menu": "3.2.1",
    "react-native-ios-utilities": "5.2.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "react-native-svg": "15.15.3",
    "zeego": "3.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/runtime": "^7.28.6",
    "@better-auth/expo": "^1.4.19",
    "@jest/reporters": "^29.7.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.1.7",
    "babel-preset-expo": "^55.0.10",
    "detox": "^20.27.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-expo": "~55.0.0",
    "react-test-renderer": "19.2.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "peerDependencies": {
    "react-native-svg": "15.15.3"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "packageManager": "bun@1.3.10",
  "expo": {
    "install": {
      "exclude": [
        "react-native-safe-area-context"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [],
        "listUnknownPackages": [
          "@biomejs/biome"
        ]
      }
    }
  },
  "trustedDependencies": [
    "@clerk/shared",
    "@parcel/watcher",
    "browser-tabs-lock",
    "core-js"
  ]
}
