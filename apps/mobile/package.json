{
  "name": "@hominem/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "bash scripts/run-variant.sh dev expo start --dev-client",
    "target": "bash scripts/dev-target.sh",
    "target:sim": "bash scripts/dev-target.sh simulator",
    "target:device": "bash scripts/dev-target.sh device",
    "lint": "bunx oxlint ./app",
    "format": "bunx oxfmt ./app",
    "ios": "bash scripts/run-variant.sh dev expo run:ios",
    "prebuild": "bash scripts/run-variant.sh dev expo prebuild",
    "prebuild:dev": "bash scripts/run-variant.sh dev expo prebuild",
    "prebuild:e2e": "bash scripts/run-variant.sh e2e expo prebuild --platform ios --clean",
    "build:development": "bun run validate:eas:profiles && eas build --profile development --platform ios",
    "build:e2e": "bun run validate:eas:profiles && eas build --profile e2e --platform ios",
    "build:preview": "bun run validate:eas:profiles && eas build --profile preview --platform ios",
    "build:production": "bun run validate:eas:profiles && eas build --profile production --platform ios",
    "build:update:preview": "bash scripts/run-variant.sh preview eas update --platform ios --branch preview --clear-cache",
    "web": "expo start --web",
    "validate:eas:profiles": "bash scripts/validate-eas-profile.sh",
    "test:e2e": "bun run test:e2e:auth:critical",
    "test:auth": "bun run test:unit:auth && bun run test:integration && bun run test:screens:auth && bun run test:e2e:auth:critical",
    "test:unit": "bun run test:unit:auth",
    "test:integration": "vitest run --config vitest.config.ts tests/integration/",
    "test:integration:auth": "vitest run --config vitest.config.ts tests/integration/auth-contract.integration.test.ts tests/integration/auth-flow.integration.test.ts",
    "test:screens:auth": "node ./node_modules/jest/bin/jest.js --config jest.screen.config.cjs",
    "test": "bun run test:unit:auth && bunx vitest run --config vitest.config.ts tests/integration/*.integration.test.ts",
    "test:unit:auth": "vitest run --config vitest.config.ts tests/auth-state-machine.test.ts tests/auth-provider-utils.test.ts tests/auth-route-guard.test.ts tests/startup-metrics.test.ts tests/auth-validation.test.ts tests/auth-boot.test.ts",
    "test:e2e:build:ios": "bun run prebuild:e2e && detox build -c ios.sim.e2e",
    "test:e2e:auth:critical": "detox test -c ios.sim.e2e --testPathPattern=e2e/auth.mobile.e2e.js --cleanup --retries 0",
    "test:e2e:auth:mobile": "bun run test:e2e:auth:critical",
    "test:e2e:smoke": "detox test -c ios.sim.e2e --testPathPattern=e2e/smoke.mobile.e2e.js --cleanup",
    "android": "expo run:android"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.2.12",
    "@better-auth/passkey": "^1.5.4",
    "@expo/vector-icons": "^14.0.0",
    "@hominem/auth": "workspace:*",
    "@hominem/hono-client": "workspace:*",
    "@hominem/hono-rpc": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/drawer": "^7.0.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/restyle": "^2.4.4",
    "@tanstack/react-query": "^5.60.5",
    "better-auth": "^1.4.19",
    "expo": "~54.0.0",
    "expo-av": "16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.0",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.0",
    "expo-keep-awake": "~14.0.0",
    "expo-linking": "~8.0.11",
    "expo-network": "^55.0.8",
    "expo-notifications": "~0.32.0",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~15.1.0",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-ios-context-menu": "3.2.1",
    "react-native-ios-utilities": "5.2.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.20.0",
    "react-native-worklets": "0.5.1",
    "zeego": "3.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/runtime": "^7.28.6",
    "@better-auth/expo": "^1.4.19",
    "@jest/reporters": "^29.7.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.11",
    "babel-preset-expo": "^55.0.10",
    "detox": "^20.27.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "packageManager": "npm@10.1.0",
  "expo": {
    "install": {
      "exclude": [
        "react-native-safe-area-context"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": [
          "@biomejs/biome"
        ]
      }
    }
  },
  "trustedDependencies": [
    "@clerk/shared",
    "@parcel/watcher",
    "browser-tabs-lock",
    "core-js"
  ]
}
