{
  "name": "@hominem/career",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:debug": "node --inspect-brk ./node_modules/.bin/react-router dev",
    "lint": "pnpm dlx oxlint ./app ./scripts ./tests",
    "format": "pnpm dlx oxfmt ./app ./scripts ./tests",
    "preview": "pnpm build && vite preview",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest run --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "react-router typegen && tsgo --noEmit",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:migrate": "pnpm exec drizzle-kit migrate",
    "db:inject-jobs": "pnpm exec tsx scripts/inject-job-applications.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.19",
    "@ai-sdk/openai": "^1.3.22",
    "@hominem/ui": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "@tanstack/react-query": "^5.80.6",
    "ai": "^4.3.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "isbot": "^5.1.27",
    "lucide-react": "0.576.0",
    "next-themes": "^0.4.6",
    "pdf2json": "^3.1.6",
    "postgres": "^3.4.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.57.0",
    "react-image-crop": "^11.0.10",
    "react-router": "7.14.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.1.8",
    "@tanstack/react-query-devtools": "^5.80.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.4.0",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.1.7",
    "@types/react-image-crop": "^8.1.6",
    "@vitest/coverage-v8": "4.1.2",
    "drizzle-kit": "^0.31.1",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.4",
    "tsx": "^4.10.0",
    "vite": "8.0.8",
    "vitest": "4.1.2"
  }
}
