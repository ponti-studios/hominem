{
  "name": "@hominem/career",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build && mkdir -p build/lib && cp -R app/lib/prompts build/lib/",
    "dev": "react-router dev",
    "dev:clean": "rm -rf node_modules/.vite && react-router dev",
    "dev:debug": "node --inspect-brk ./node_modules/.bin/react-router dev",
    "lint": "oxlint app tests --fix",
    "format": "oxfmt app tests --write",
    "preview": "pnpm build && vite preview",
    "start": "react-router-serve ./build/server/index.js --port=${PORT:-3000}",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest run --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "react-router typegen && tsgo --noEmit"
  },
  "dependencies": {
    "@hominem/ai": "workspace:*",
    "@hominem/auth": "workspace:*",
    "@hominem/db": "workspace:*",
    "@hominem/storage": "workspace:*",
    "@hominem/ui": "workspace:*",
    "@hominem/utils": "workspace:*",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@tanstack/react-query": "^5.80.6",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "isbot": "^5.1.27",
    "lucide-react": "0.576.0",
    "pdf2json": "^3.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.57.0",
    "react-image-crop": "^11.0.10",
    "react-router": "7.15.1",
    "tailwind-merge": "^3.3.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.4.0",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.1.7",
    "@vitest/coverage-v8": "4.1.2",
    "jsdom": "^26.1.0",
    "msw": "^2.12.13",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.10.0",
    "tw-animate-css": "^1.3.4",
    "vite": "8.0.16",
    "vitest": "4.1.2"
  }
}
