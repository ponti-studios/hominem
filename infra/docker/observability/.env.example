# ClickStack observability configuration
# Copy this file to .env and fill in values (this file is safe to commit)
# .env is gitignored

# ClickHouse credentials (leave empty for local default setup)
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ClickHouse database for telemetry data
CLICKHOUSE_DATABASE=default

# Log verbosity: error | warn | info | debug
HYPERDX_LOG_LEVEL=error
