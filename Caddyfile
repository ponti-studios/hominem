{
	# Development-specific global options
	debug
	local_certs
	# auto_https disable_redirects

	servers {
		# Timeouts
		timeouts {
			read_body 10s
			read_header 10s
			write 30s
			idle 60s
		}
	}

	# Logging to stdout instead of file to avoid permission issues
	log {
		output stdout
		level INFO
	}
}

(common) {
	# REMOVED: bind 127.0.0.1 (Let Caddy manage bindings)

	# Security headers
	header {
		# CORS for local development
		# Access-Control-Allow-Origin "*"
		# Security headers
		Strict-Transport-Security "max-age=31536000;"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Enable compression
	encode zstd gzip

	# Custom error pages
	handle_errors {
		respond "* {http.error.status_code} {http.error.status_text}"
	}
}

rocco.hominem.test {
	import common
	reverse_proxy 127.0.0.1:4446
}

finance.hominem.test {
	import common
	reverse_proxy 127.0.0.1:4444
}

notes.hominem.test {
	import common
	reverse_proxy 127.0.0.1:4445
}
