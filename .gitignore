# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.crush

# Allow packages/env despite global gitignore having ENV/
!packages/env/
!packages/env/**

# dependencies
node_modules

# testing
coverage
playwright-report
test-results

# build output
.react-router
out/
output/
build
logs
dist
results.json
storybook-static/

# misc
.DS_Store
*.pem
*.sqlite
*.sqlite3
*.tsbuildinfo
results/

# bun
# Note: lockfile should be committed for monorepos to ensure consistent dependencies
# bun.lock

# Google credentials
credentials.json
token.json
.auth/
*.p8

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# local env files
.env
.env.local
.env.development*
.env.test*
.env.production*
!/packages/core/env

# TypeScript build cache
.cache/

# TypeScript
.type-analysis
.type-traces
.type-diagnosis-traces

# @ark/attest snapshots (commit these to track type performance over time)
.attest/

# turbo
.turbo

# throw-away helpers
test-import.ts
.tmp-read-otp.ts

# voice/audio review files
.tmp/

# local logs
tmp/


# git worktrees
.worktrees/
