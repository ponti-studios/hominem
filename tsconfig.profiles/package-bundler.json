{
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipDefaultLibCheck": true,
    "composite": true,
    "declaration": true,
    "incremental": true,
    "isolatedModules": true,
    "allowJs": false,
    "checkJs": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  }
}
