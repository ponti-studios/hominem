{
  "formatter": {
    "external": {
      "command": "oxfmt",
      "arguments": [
        "--stdin-filepath",
        "{buffer_path}",
        "-c",
        "/Users/charlesponti/Developer/hominem/.oxfmtrc.json"
      ]
    }
  },
  "format_on_save": "on",
  "inlay_hints": {
    "enabled": true,
    "show_parameter_hints": false,
    "show_type_hints": false
  },
  "languages": {
    "CSS": {
      "language_servers": ["tailwindcss-intellisense-css", "!vscode-css-language-server", "..."]
    }
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx", "cn"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)"]
        }
      }
    }
  }
}
