{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["package.json", "bun.lock", ".env.local", "**/.env.*local"],
  "globalEnv": [
    "R2_ENDPOINT",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "VITE_APP_BASE_URL",
    "VITE_R2_DOMAIN",
    "DATABASE_URL",
    "GITHUB_TOKEN",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_REDIRECT_URI",
    "OPENAI_API_KEY",
    "OPENROUTER_API_KEY",
    "REDIS_URL",
    "RESEND_API_KEY"
  ],
  "concurrency": "8",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".react-router/**", "app/routes/+types/**/*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "db:migrate": {
      "dependsOn": ["^build"]
    },
    "db:rollback": {
      "dependsOn": ["^build"]
    },
    "db:status": {
      "dependsOn": ["^build"]
    },
    "format": {
      "inputs": ["src/**/*.{ts,tsx,js,jsx,json,md}", "app/**/*.{ts,tsx,js,jsx,json,md}"]
    },
    "lint": {
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx,json,md,css}",
        "app/**/*.{ts,tsx,js,jsx,json,md,css}",
        "packages/platform/ui/tools/stylelint-config-void.cjs"
      ]
    },
    "start": {
      "dependsOn": ["build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "app/**/*.{ts,tsx,js,jsx}",
        "test/**/*.{ts,tsx,js,jsx}"
      ]
    },
    "typegen": {
      "outputs": [".react-router/**", "app/routes/+types/**/*"]
    },
    "typecheck": {
      "dependsOn": ["^build", "typegen"],
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json"]
    }
  }
}
