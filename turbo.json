{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["package.json", "pnpm-lock.yaml", ".env", ".env.*"],
  "globalEnv": [
    "NODE_ENV",
    "API_URL",
    "WEB_URL",
    "FINANCE_URL",
    "DATABASE_URL",
    "REDIS_URL",
    "BETTER_AUTH_SECRET",
    "AUTH_PASSKEY_RP_ID",
    "AUTH_PASSKEY_ORIGIN",
    "AUTH_COOKIE_DOMAIN",
    "AUTH_E2E_SECRET",
    "AUTH_EMAIL_OTP_EXPIRES_SECONDS",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "RESEND_FROM_NAME",
    "SEND_EMAILS",
    "OPENROUTER_API_KEY",
    "AI_MODEL",
    "R2_ENDPOINT",
    "R2_BUCKET_NAME",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "SENTRY_DSN",
    "SERVICE_NAME",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_EXPORTER_OTLP_PROTOCOL",
    "OTEL_SERVICE_NAME",
    "OTEL_SERVICE_NAMESPACE",
    "OTEL_DEPLOYMENT_ENVIRONMENT",
    "OTEL_TRACES_SAMPLER_ARG",
    "OTEL_LOGS_EXPORTER",
    "VITE_PUBLIC_API_URL",
    "VITE_POSTHOG_HOST",
    "VITE_OTEL_DISABLED",
    "VITE_OTEL_SERVICE_NAME",
    "VITE_OTEL_SERVICE_VERSION",
    "VITE_OTEL_DEPLOYMENT_ENVIRONMENT",
    "VITE_OTEL_EXPORTER_OTLP_ENDPOINT",
    "VITE_OTEL_TRACES_SAMPLER_ARG",
    "EXPO_PUBLIC_API_BASE_URL",
    "EXPO_PUBLIC_MOBILE_PASSKEY_ENABLED",
    "EXPO_PUBLIC_POSTHOG_API_KEY",
    "EXPO_PUBLIC_POSTHOG_HOST",
    "EXPO_PUBLIC_SENTRY_DSN",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "../../.env", "../../.env.*"],
      "outputs": ["dist/**", "build/**", ".react-router/**", "app/routes/+types/**/*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env*", "../../.env", "../../.env.*"]
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "outputs": []
    },
    "preview": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "../../.env", "../../.env.*"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*", "../../.env", "../../.env.*"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", ".env*", "../../.env", "../../.env.*"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "../../.env", "../../.env.*"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true,
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "../../.env", "../../.env.*"],
      "outputs": []
    }
  }
}
