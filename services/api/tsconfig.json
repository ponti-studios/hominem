{
  "extends": "../../tsconfig.profiles/bundler-noemit.json",
  "compilerOptions": {
    "composite": false,
    "tsBuildInfoFile": "./.cache/tsconfig.tsbuildinfo",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "build", ".turbo", ".cache", "coverage", "*.tsbuildinfo"]
  // Deliberately NOT wired into the composite project-reference graph:
  // rpc/app.ts's `typeof rpcApp` inference re-exports types from these
  // packages (AIUsageFeature, AffordabilityVerdict, ...), and once those
  // packages are real composite projects, TS's "portable type" check
  // (TS2883) refuses to infer AppType without an explicit annotation —
  // which would defeat Hono's RPC type-inference pattern. This package
  // keeps resolving its dependencies via plain source, same as before.
}
