# Environment
NODE_ENV=""

# API port
PORT=4040
API_URL=http://localhost:4040

# Data
DATABASE_URL=""
REDIS_URL=""

# Authentication
AUTH_PASSKEY_RP_ID=api.ponti.io
AUTH_PASSKEY_ORIGIN=https://api.ponti.io
BETTER_AUTH_SECRET=""

# Storage
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# UI
NOTES_URL=""

# Email
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME=""

# AI
# Full model list: https://openrouter.ai/models
AI_PROVIDER=openrouter
AI_MODEL="openai/gpt-4o-mini-2024-07-18"
OPENROUTER_API_KEY=""

# Apple Auth
APPLE_CLIENT_ID=com.pontistudios.hakumi.auth
APPLE_TEAM_ID=3QHJ2KN8AL
AUTH_E2E_ENABLED=true
AUTH_E2E_SECRET=otp-secret
AUTH_TEST_OTP_ENABLED=true
AUTH_TEST_OTP_TTL_SECONDS=300

# Observability
# Dev:  docker compose -f infra/compose/base.yml -f infra/compose/dev.yml up -d  →  http://localhost:16686
# Prod: set OTEL_EXPORTER_OTLP_ENDPOINT to Sentry's OTLP endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=hominem-api
OTEL_DEPLOYMENT_ENVIRONMENT=development
OTEL_TRACES_SAMPLER_ARG=1.0
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
