# Environment
NODE_ENV=""

# API port
PORT=4040
API_URL=http://localhost:4040

# Data
DATABASE_URL=""
REDIS_URL=""

# Authentication
AUTH_PASSKEY_RP_ID=api.ponti.io
AUTH_PASSKEY_ORIGIN=https://api.ponti.io
BETTER_AUTH_SECRET=""

# Storage
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# UI
NOTES_URL=""

# Google
GOOGLE_API_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Twitter
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# Email
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME=""

# Services
GEOCODE_EARTH_API_KEY=""
GOOGLE_PLACES_API_KEY=""
TAVILY_API_KEY=""

# AI
# Full model list: https://openrouter.ai/models
