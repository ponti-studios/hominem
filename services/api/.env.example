# API service
NODE_ENV="development"
# No default — Railway injects PORT per deployed service (api vs. worker).
# Falls back to 4040 (api) / 3001 (worker health check) locally when unset.
PORT=4040
API_URL="http://localhost:4040"
WEB_URL="http://localhost:4445"
CAREER_URL="http://localhost:4451"
FINANCE_URL="http://localhost:4444"

# Data and queues
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5434/app"
REDIS_URL="redis://localhost:6379"

# Authentication
# Required — no default. Better Auth signs session cookies with this secret;
# the process fails to boot without it.
BETTER_AUTH_SECRET=""
AUTH_PASSKEY_RP_ID="api.ponti.io"
AUTH_PASSKEY_ORIGIN="https://api.ponti.io"
AUTH_PASSKEY_APPLE_APP_IDS="3QHJ2KN8AL.com.pontistudios.hakumi,3QHJ2KN8AL.com.pontistudios.hakumi.dev"
AUTH_COOKIE_DOMAIN=""
AUTH_E2E_ENABLED="false"
AUTH_E2E_SECRET=""
AUTH_TEST_OTP_ENABLED="false"
AUTH_TEST_OTP_TTL_SECONDS="300"
AUTH_EMAIL_OTP_EXPIRES_SECONDS="300"

# RPC and service integrations
PLAID_CLIENT_ID=""
PLAID_API_KEY=""
PLAID_ENV="sandbox"

# Email
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME=""
SEND_EMAILS="false"

# AI
AI_MODEL="qwen/qwen3.5-flash-02-23"
OPENROUTER_API_KEY=""
OPENROUTER_VOICE_CLEANUP_MODEL="qwen/qwen3.5-flash-02-23"
OPENROUTER_TASK_EXTRACTION_MODEL="qwen/qwen3.5-flash-02-23"
SAVE_VOICE_AUDIO="false"

# MCP
MCP_ENABLED_SCOPES=""
MCP_DAILY_COST_BUDGET_CENTS="100"

# Storage
R2_ENDPOINT=http://localhost:9000
R2_PUBLIC_URL=http://localhost:9000
R2_BUCKET_NAME=storage
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin

# Observability
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_SERVICE_NAME="api"
OTEL_DEPLOYMENT_ENVIRONMENT="development"
OTEL_TRACES_SAMPLER_ARG="1.0"
OTEL_LOGS_EXPORTER="http/protobuf"
