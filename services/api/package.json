{
  "name": "@hominem/api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "start": "bun src/index.ts",
    "test": "NODE_ENV=test vitest run --config vitest.config.ts --passWithNoTests",
    "test:auth:contract": "NODE_ENV=test vitest run --config vitest.contract.config.ts src/routes/auth.email-otp.contract.test.ts src/routes/auth.test-otp-route.test.ts src/routes/auth.e2e-login.test.ts src/routes/auth.rate-limit.test.ts src/routes/auth.device-contract.test.ts src/routes/auth.token-contract.test.ts --passWithNoTests",
    "test:integration": "NODE_ENV=test vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:contract": "NODE_ENV=test vitest run --config vitest.contract.config.ts --passWithNoTests",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "test:watch": "NODE_ENV=test vitest --config vitest.config.ts",
    "perf:auth-middleware": "NODE_ENV=test bun src/middleware/auth.perf.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.10",
    "@better-auth/expo": "^1.4.19",
    "@better-auth/kysely-adapter": "^1.5.4",
    "@better-auth/passkey": "^1.4.19",
    "@hominem/auth": "workspace:*",
    "@hominem/chat": "workspace:*",
    "@hominem/db": "workspace:*",
    "@hominem/env": "workspace:*",
    "@hominem/presence": "workspace:*",
    "@hominem/queues": "workspace:*",
    "@hominem/rpc": "workspace:*",
    "@hominem/services": "workspace:*",
    "@hominem/telemetry": "workspace:*",
    "@hominem/utils": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.2",
    "@sentry/node": "^8.54.0",
    "ai": "^4.3.16",
    "better-auth": "^1.4.19",
    "dotenv": "17.2.3",
    "hono": "^4.12.6",
    "hono-openapi": "^1.3.0",
    "jose": "^6.1.3",
    "plaid": "^41.4.0",
    "quansync": "^1.0.0",
    "resend": "^4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "4.1.2",
    "bullmq": "5.66.4",
    "msw": "^2.12.7",
    "vite": "8.0.3",
    "vite-tsconfig-paths": "6.0.3"
  }
}
