{
  "name": "@hominem/api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./types": {
      "types": "./src/rpc/app.ts",
      "default": "./src/rpc/app.ts"
    },
    "./finance": {
      "types": "./src/rpc/routes/finance.ts",
      "default": "./src/rpc/routes/finance.ts"
    },
    "./career": {
      "types": "./src/rpc/routes/career.ts",
      "default": "./src/rpc/routes/career.ts"
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "SERVICE_NAME=api node --watch --import tsx src/index.ts",
    "format": "oxfmt src --write",
    "format:check": "oxfmt src --check",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "start": "node dist/index.mjs",
    "start:worker": "node dist/worker.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "e2e:setup": "tsx scripts/e2e-setup.ts"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.6.13",
    "@hominem/ai": "workspace:*",
    "@hominem/auth": "workspace:*",
    "@hominem/db": "workspace:*",
    "@hominem/env": "workspace:*",
    "@hominem/finance-services": "workspace:*",
    "@hominem/queues": "workspace:*",
    "@hominem/services": "workspace:*",
    "@hominem/storage": "workspace:*",
    "@hominem/telemetry": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "@hono/standard-validator": "^0.2.0",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/hono-api-reference": "^0.10.2",
    "@sentry/node": "^8.54.0",
    "better-auth": "^1.6.13",
    "bullmq": "5.66.4",
    "dotenv": "17.2.3",
    "hono": "4.12.27",
    "hono-openapi": "^1.3.0",
    "pg": "^8.20.0",
    "resend": "^6.12.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "goose-cli": "3.25.0-a",
    "rolldown": "^1.0.0",
    "tsx": "^4.10.0"
  }
}
