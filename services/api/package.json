{
  "name": "@hominem/api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./types": {
      "types": "./src/rpc/app.ts",
      "default": "./src/rpc/app.ts"
    }
  },
  "scripts": {
    "dev": "SERVICE_NAME=hominem-api tsx --watch src/index.ts",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src",
    "migrate:deploy": "goose -dir ../../packages/core/db/migrations postgres \"$DATABASE_URL\" up",
    "start": "SERVICE_NAME=hominem-api tsx src/index.ts",
    "start:worker": "tsx src/worker.ts",
    "typecheck": "tsgo --noEmit",
    "perf:auth-middleware": "NODE_ENV=test tsx src/middleware/auth.perf.ts",
    "e2e:setup": "tsx scripts/e2e-setup.ts"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.5.4",
    "@better-auth/passkey": "^1.5.4",
    "@hominem/auth": "workspace:*",
    "@hominem/db": "workspace:*",
    "@hominem/env": "workspace:*",
    "@hominem/queues": "workspace:*",
    "@hominem/services": "workspace:*",
    "@hominem/storage": "workspace:*",
    "@hominem/telemetry": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@opentelemetry/api": "^1.8.0",
    "@scalar/hono-api-reference": "^0.10.2",
    "@sentry/node": "^8.54.0",
    "better-auth": "^1.4.19",
    "bullmq": "5.66.4",
    "dotenv": "17.2.3",
    "hono": "4.12.14",
    "hono-openapi": "^1.3.0",
    "pg": "^8.20.0",
    "resend": "^4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "goose-cli": "3.25.0-a",
    "tsx": "^4.10.0"
  }
}
