{
  "name": "@hominem/api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "lsof -ti:4040 | xargs kill -9 2>/dev/null; bun --watch src/index.ts",
    "auth:apple:client-secret": "bun scripts/generate-apple-client-secret.ts",
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "start": "bun src/index.ts | pino-pretty",
    "test": "NODE_ENV=test vitest run --passWithNoTests",
    "test:auth": "NODE_ENV=test vitest run src/routes/auth.email-otp.contract.test.ts src/routes/auth.passkey.contract.test.ts src/routes/auth.test-otp-route.test.ts src/routes/auth.e2e-login.test.ts src/routes/auth.rate-limit.test.ts src/routes/auth.token-contract.test.ts src/routes/auth.middleware.test.ts",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "test:watch": "NODE_ENV=test vitest",
    "perf:auth-middleware": "NODE_ENV=test bun src/middleware/auth.perf.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.10",
    "@better-auth/expo": "^1.4.19",
    "@better-auth/passkey": "^1.4.19",
    "@hominem/auth": "workspace:*",
    "@hominem/db": "workspace:*",
    "@hominem/env": "workspace:*",
    "@hominem/finance-services": "workspace:*",
    "@hominem/health-services": "workspace:*",
    "@hominem/hono-rpc": "workspace:*",
    "@hominem/jobs-services": "workspace:*",
    "@hominem/lists-services": "workspace:*",
    "@hominem/queues": "workspace:*",
    "@hominem/services": "workspace:*",
    "@hominem/utils": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@sentry/node": "^8.54.0",
    "ai": "^4.3.16",
    "better-auth": "^1.4.19",
    "bullmq": "5.66.4",
    "dotenv": "17.2.3",
    "hono": "^4.12.6",
    "jose": "^6.1.3",
    "plaid": "^28.0.0",
    "resend": "^4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.0.16",
    "msw": "^2.12.7",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.0.3",
    "vitest": "4.0.16"
  }
}
