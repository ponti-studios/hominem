{
  "extends": ["../../.oxlintrc.json"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@hominem/ui", "@hominem/ui/*"],
            "message": "API must not import UI components directly. Keep the transport layer UI-agnostic."
          },
        ]
      }
    ]
  },
  "ignorePatterns": ["dist", "build", ".next", "node_modules"]
}
