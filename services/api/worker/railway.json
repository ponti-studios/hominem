{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/services/api/Dockerfile",
    "watchPatterns": [
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/turbo.json",
      "/services/api/**",
      "/packages/**"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @hakumi/api run start:worker",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10,
    "sleepApplication": false,
    "region": "us-west2",
    "overlapSeconds": 0,
    "drainingSeconds": 120
  }
}
