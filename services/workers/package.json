{
  "name": "@hominem/workers",
  "version": "0.1.0",
  "private": true,
  "description": "background workers for file uploads",
  "files": [
    "build"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "bunx oxlint ./src",
    "format": "bunx oxfmt ./src"
  },
  "dependencies": {
    "@hominem/db": "workspace:*",
    "@hominem/jobs-services": "workspace:*",
    "@hominem/services": "workspace:*",
    "@hominem/telemetry": "workspace:*",
    "@hominem/utils": "workspace:*",
    "bullmq": "5.66.4",
    "dotenv": "17.2.3",
    "effect": "^3.16.10",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "vitest": "4.0.16"
  }
}
