PORT=4447

APP_BASE_URL=""

# Data
DATABASE_URL=""
REDIS_URL=""

# Google
GOOGLE_API_KEY=""

# Plaid
PLAID_API_KEY=""
PLAID_CLIENT_ID=""

# Storage
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Observability (OpenTelemetry)
# Sends telemetry to local stack at http://localhost:4318
# Start the stack: ~/.local/observability/observability.sh start
# View dashboards: http://localhost:3000 (admin/admin)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=hominem-workers
OTEL_DEPLOYMENT_ENVIRONMENT=development
OTEL_TRACES_SAMPLER_ARG=1.0
