{
  "name": "@hominem/rpc",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./finance": {
      "types": "./src/finance.ts",
      "default": "./src/finance.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./voice-events": {
      "types": "./src/voice-events.ts",
      "default": "./src/voice-events.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@hominem/api": "workspace:*",
    "@hominem/chat": "workspace:*",
    "@tanstack/react-query": "5.100.10",
    "hono": "4.12.25",
    "zod": "catalog:"
  },
  "devDependencies": {
    "react": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  }
}
