{
  "name": "@hominem/rpc",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./voice-events": {
      "types": "./src/voice-events.ts",
      "default": "./src/voice-events.ts"
    },
    "./domains/finance": {
      "types": "./src/domains/finance.ts",
      "default": "./src/domains/finance.ts"
    },
    "./schemas/*": {
      "types": "./src/schemas/*.ts",
      "default": "./src/schemas/*.ts"
    },
    "./types/finance/*": {
      "types": "./src/types/finance/*.ts",
      "default": "./src/types/finance/*.ts"
    }
  },
  "scripts": {
    "build": "true",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@hominem/chat": "workspace:*",
    "@tanstack/react-query": "5.100.10",
    "hono": "4.12.25",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "react": "19.2.3"
  },
  "peerDependencies": {
    "react": "19.2.3"
  }
}
