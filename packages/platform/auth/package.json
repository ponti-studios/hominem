{
  "name": "@hominem/auth",
  "version": "0.0.0",
  "description": "Unified authentication package for Hominem apps (web, mobile, CLI)",
  "type": "module",
  "exports": {
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./shared/error-contract": {
      "types": "./src/shared/error-contract.ts",
      "default": "./src/shared/error-contract.ts"
    },
    "./shared/mask-email": {
      "types": "./src/shared/mask-email.ts",
      "default": "./src/shared/mask-email.ts"
    },
    "./shared/redirect-policy": {
      "types": "./src/shared/redirect-policy.ts",
      "default": "./src/shared/redirect-policy.ts"
    },
    "./shared/ux-contract": {
      "types": "./src/shared/ux-contract.ts",
      "default": "./src/shared/ux-contract.ts"
    },
    "./client/provider": {
      "types": "./src/client/provider.tsx",
      "default": "./src/client/provider.tsx"
    },
    "./client/passkey": {
      "types": "./src/client/passkey.ts",
      "default": "./src/client/passkey.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.4.19",
    "@hominem/db": "workspace:*",
    "@hominem/env": "workspace:*",
    "better-auth": "^1.4.19"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "19.2.10",
    "@typescript/native-preview": "7.0.0-dev.20260415.1",
    "react": "19.2.0",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "react": "19.2.0"
  }
}
