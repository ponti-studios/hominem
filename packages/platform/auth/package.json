{
  "name": "@hominem/auth",
  "version": "0.0.0",
  "description": "Unified authentication package for Hominem apps (web, mobile, CLI)",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./server": "./src/server/index.ts",
    "./server-utils": "./src/server/session.ts",
    "./step-up-actions": "./src/shared/step-up-actions.ts",
    "./redirect-policy": "./src/shared/redirect-policy.ts",
    "./ux-contract": "./src/shared/ux-contract.ts",
    "./client": "./src/client/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hominem/db": "workspace:*",
    "@hominem/env": "workspace:*",
    "@hominem/utils": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "19.2.10",
    "react": "19.2.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "react": "19.2.0"
  }
}
