{
  "name": "@hominem/auth",
  "version": "0.0.0",
  "description": "Unified authentication package for Hominem apps (web, mobile, CLI)",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./step-up-actions": {
      "types": "./src/shared/step-up-actions.ts",
      "default": "./src/shared/step-up-actions.ts"
    },
    "./redirect-policy": {
      "types": "./src/shared/redirect-policy.ts",
      "default": "./src/shared/redirect-policy.ts"
    },
    "./server-utils": {
      "types": "./src/server-utils.ts",
      "default": "./src/server-utils.ts"
    },
    "./ux-contract": {
      "types": "./src/shared/ux-contract.ts",
      "default": "./src/shared/ux-contract.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.4.19",
    "@hominem/env": "workspace:*",
    "better-auth": "^1.4.19"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "19.2.10",
    "jsdom": "^28.1.0",
    "react": "19.2.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "19.2.0"
  }
}
