{
  "extends": "../../../tsconfig.profiles/react-bundler-lib.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./build",
    "tsBuildInfoFile": "../../../.cache/ui.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    ".turbo",
    ".cache",
    "coverage",
    "*.tsbuildinfo"
  ]
}
