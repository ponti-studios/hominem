    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.4.0",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.1.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/browser": "4.1.2",
    "@vitest/browser-playwright": "4.1.2",
    "expo-clipboard": "~55.0.9",
