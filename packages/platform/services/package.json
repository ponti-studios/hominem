{
  "name": "@hominem/services",
  "version": "0.0.0",
  "description": "Business logic and services",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./emails": {
      "types": "./src/resend.ts",
      "default": "./src/resend.ts"
    },
    "./resend": {
      "types": "./src/resend.ts",
      "default": "./src/resend.ts"
    },
    "./files": {
      "types": "./src/files.ts",
      "default": "./src/files.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    },
    "./ai-model": {
      "types": "./src/ai-model.ts",
      "default": "./src/ai-model.ts"
    },
    "./redis": {
      "types": "./src/redis.ts",
      "default": "./src/redis.ts"
    },
    "./test-utils/google-api-mocks": {
      "types": "./src/test-utils/google-api-mocks.ts",
      "default": "./src/test-utils/google-api-mocks.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@hominem/env": "workspace:*",
    "@hominem/utils": "workspace:*",
    "ai": "^4.3.19",
    "bullmq": "5.66.4",
    "dotenv": "17.2.3",
    "ioredis": "5.8.2",
    "mammoth": "^1.9.1",
    "openai": "4.83.0",
    "pdf2json": "^3.1.6",
    "resend": "^4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "5.9.3"
  }
}
