{
  "name": "@hakumi/rpc",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./schemas/*": {
      "types": "./src/schemas/*.ts",
      "default": "./src/schemas/*.ts"
    },
    "./voice-events": {
      "types": "./src/voice-events.ts",
      "default": "./src/voice-events.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@hakumi/chat": "workspace:*",
    "@tanstack/react-query": "5.90.16",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "react": "19.2.0"
  },
  "peerDependencies": {
    "react": "19.2.0"
  }
}
