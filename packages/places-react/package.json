{
  "name": "@hominem/places-react",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./places/detail": "./src/components/places/detail/index.ts",
    "./places/list": "./src/components/places/list/index.ts",
    "./places/visits": "./src/components/places/visits/index.ts",
    "./places/map": "./src/components/places/map/index.ts",
    "./places/utilities": "./src/components/places/utilities/index.ts",
    "./hooks": "./src/hooks/index.ts"
  },
  "scripts": {
    "clean": "rm -rf build",
    "format": "bunx oxfmt ./src",
