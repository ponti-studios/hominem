    "@hominem/hono-client": "workspace:*",
    "@hominem/hono-rpc": "workspace:*",
    "@tanstack/react-query": "5.90.16",
    "@vis.gl/react-google-maps": "^1.7.1",
    "lucide-react": "^0.575.0",
    "react": "19.2.0"
  },
  "devDependencies": {
    "@types/react": "19.2.10",
    "@types/react-dom": "19.1.7",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.0.3",
    "vitest": "4.0.16"
  },
  "peerDependencies": {
    "react": "19.2.0"
  }
