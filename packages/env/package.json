{
  "name": "@hominem/env",
  "version": "0.0.0",
  "description": "Unified environment handling, schemas, and brand identity",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./base": {
      "types": "./src/base.ts",
      "default": "./src/base.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "default": "./src/api.ts"
    },
    "./web": {
      "types": "./src/web.ts",
      "default": "./src/web.ts"
    },
    "./brand": {
      "types": "./src/brand.ts",
      "default": "./src/brand.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "dev": "tsgo --watch --preserveWatchOutput",
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt src --write",
    "lint": "oxlint src --fix"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {}
}
