{
  "name": "@hominem/events",
  "version": "0.0.0",
  "description": "Personal life tracking — habits, goals, health, visits. How you spend your time and energy.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hominem/db": "workspace:*",
    "@hominem/services": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
