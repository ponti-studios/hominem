{
  "name": "@hominem/presence",
  "version": "0.0.0",
  "description": "Personal life tracking — habits, goals, health, visits. How you spend your time and energy.",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hominem/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "5.9.3"
  }
}
