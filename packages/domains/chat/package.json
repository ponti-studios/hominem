{
  "name": "@hominem/chat",
  "version": "0.0.0",
  "description": "Chat and messaging services",
  "type": "module",
  "sideEffects": false,
  "types": "./src/public.ts",
  "exports": {
    ".": {
      "types": "./src/public.ts",
      "default": "./src/public.ts"
    },
    "./server": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types-only.ts",
      "default": "./src/types-only.ts"
    },
    "./ui": {
      "types": "./src/session-artifacts.ts",
      "default": "./src/session-artifacts.ts"
    },
    "./react": {
      "types": "./src/use-chat-lifecycle.ts",
      "default": "./src/use-chat-lifecycle.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "default": "./src/constants.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src"
  },
  "dependencies": {
    "@hominem/db": "workspace:*",
    "@hominem/utils": "workspace:*",
    "@langchain/textsplitters": "^1.0.1",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "react": "19.2.0"
  },
  "peerDependencies": {
    "react": "19.2.0"
  }
}
