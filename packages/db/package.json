{
  "name": "@hominem/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    },
    "./test/*": {
      "types": "./src/test/*.ts",
      "default": "./src/test/*.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsgo --watch --preserveWatchOutput",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "format": "oxfmt src --write",
    "format:check": "oxfmt src --check",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix"
  },
  "dependencies": {
    "@hominem/utils": "workspace:*",
    "kysely": "^0.28.17",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "dotenv": "17.2.3",
    "kysely-codegen": "^0.20.0",
    "vitest": "4.1.0"
  }
}
