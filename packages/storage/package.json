{
  "name": "@hominem/storage",
  "version": "0.0.0",
  "description": "Storage services and upload policy",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./constants": {
      "types": "./src/upload-policy.ts",
      "default": "./src/upload-policy.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt src --write",
    "lint": "oxlint src --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.529.0",
    "@aws-sdk/s3-request-presigner": "^3.529.0",
    "@hominem/utils": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.4.0"
  }
}
