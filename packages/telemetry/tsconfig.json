{
  "extends": "../../tsconfig.profiles/node-lib.json",
  "compilerOptions": {
    "tsBuildInfoFile": "../../.cache/telemetry.tsbuildinfo",
    "rootDir": "src",
    "outDir": "./build",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    ".turbo",
    ".cache",
    "coverage",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__",
    "**/__mocks__",
    "*.tsbuildinfo"
  ]
}
