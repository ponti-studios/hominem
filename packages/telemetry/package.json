{
  "name": "@hominem/telemetry",
  "version": "0.1.0",
  "description": "Shared logging primitives for Hominem services and apps",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./src/node.ts"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt src --write",
    "format:check": "oxfmt src --check"
  }
}
