{
  "name": "@hominem/utils",
  "version": "0.0.0",
  "description": "Random utilities",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./storage": "./src/storage/index.ts",
    "./consts": "./src/consts.ts",
    "./dates": "./src/dates.ts",
    "./headers": "./src/headers.ts",
    "./images": "./src/images.ts",
    "./google": "./src/google.ts",
    "./http": "./src/http.ts",
    "./location": "./src/location/index.ts",
    "./logger": "./src/logger.ts",
    "./client-logger": "./src/client-logger.ts",
    "./markdown": "./src/markdown/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./scraping": "./src/scraping/index.ts",
    "./time": "./src/time.ts",
    "./types/change-management": "./src/types/change-management.ts"
  },
  "scripts": {
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit",
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.529.0",
    "@aws-sdk/s3-request-presigner": "^3.529.0",
    "@langchain/core": "^1.1.29",
    "@langchain/textsplitters": "^1.0.1",
    "date-fns": "^3.6.0",
    "langchain": "^1.2.28",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
