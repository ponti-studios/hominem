{
  "name": "@hominem/services",
  "version": "0.0.0",
  "description": "Business logic and services",
  "type": "module",
  "types": "./src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./emails": {
      "types": "./src/resend.ts",
      "default": "./src/resend.ts"
    },
    "./resend": {
      "types": "./src/resend.ts",
      "default": "./src/resend.ts"
    },
    "./files": {
      "types": "./src/files.ts",
      "default": "./src/files.ts"
    },
    "./fixtures": {
      "types": "./src/fixtures.ts",
      "default": "./src/fixtures.ts"
    },
    "./google-calendar": {
      "types": "@hominem/db/build/google-calendar.service.d.ts",
      "default": "@hominem/db"
    },
    "./logger": {
      "types": "./src/logger.ts",
      "default": "./src/logger.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    },
    "./queues": {
      "types": "./src/queues.ts",
      "default": "./src/queues.ts"
    },
    "./redis": {
      "types": "./src/redis.ts",
      "default": "./src/redis.ts"
    },
    "./test-utils/google-api-mocks": {
      "types": "./src/test-utils/google-api-mocks.ts",
      "default": "./src/test-utils/google-api-mocks.ts"
    },
    "./travel": {
      "types": "./src/travel/index.ts",
      "default": "./src/travel/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@hominem/utils": "workspace:*",
    "bullmq": "5.66.4",
    "csv-parser": "^3.2.0",
    "dotenv": "17.2.3",
    "googleapis": "^170.0.0",
    "ioredis": "5.8.2",
    "mammoth": "^1.9.1",
    "ai": "^4.3.19",
    "openai": "4.83.0",
    "pdf2json": "^3.1.6",
    "resend": "^4.0.1",
    "uuid": "^11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
