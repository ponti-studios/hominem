{
  "name": "@hominem/chat",
  "version": "0.0.0",
  "description": "Chat and messaging services",
  "type": "module",
  "sideEffects": false,
  "types": "./src/public.ts",
  "exports": {
    ".": {
      "types": "./src/public.ts",
      "default": "./src/public.ts"
    },
    "./types": {
      "types": "./src/types-only.ts",
      "default": "./src/types-only.ts"
    },
    "./ui": {
      "types": "./src/session-artifacts.ts",
      "default": "./src/session-artifacts.ts"
    },
    "./react": {
      "types": "./src/use-chat-lifecycle.ts",
      "default": "./src/use-chat-lifecycle.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "default": "./src/constants.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt src --write",
    "lint": "oxlint src --fix"
  },
  "dependencies": {
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "react": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  }
}
