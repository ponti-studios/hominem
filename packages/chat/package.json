{
  "name": "@hominem/chat-services",
  "version": "0.0.0",
  "description": "Chat and messaging services",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types-only.ts",
    "./ui": "./src/session-artifacts.ts"
  },
  "scripts": {
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit",
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hominem/db": "workspace:*",
    "@hominem/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.18.13",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
