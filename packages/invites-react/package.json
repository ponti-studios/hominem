{
  "name": "@hominem/invites-react",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./received": "./src/components/received/index.ts",
    "./sent": "./src/components/sent/index.ts",
    "./actions": "./src/components/actions/index.ts",
    "./hooks": "./src/hooks/index.ts"
  },
  "scripts": {
    "clean": "rm -rf build",
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@hominem/ui": "workspace:*",
    "@hominem/invites-services": "workspace:*",
    "@hominem/hono-client": "workspace:*",
    "@hominem/hono-rpc": "workspace:*",
    "@tanstack/react-query": "5.90.16",
    "lucide-react": "^0.575.0",
    "react": "19.2.0"
  },
  "devDependencies": {
    "@types/react": "19.2.10",
    "@types/react-dom": "19.1.7",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.0.3",
    "vitest": "4.0.16"
  },
  "peerDependencies": {
    "react": "19.2.0"
  }
}
