{
  "name": "@hominem/auth",
  "version": "0.0.0",
  "description": "Unified authentication package for Hominem apps (web, mobile, CLI)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./shared/mask-email": {
      "types": "./src/shared/mask-email.ts",
      "default": "./src/shared/mask-email.ts"
    },
    "./shared/validation": {
      "types": "./src/shared/validation.ts",
      "default": "./src/shared/validation.ts"
    },
    "./shared/redirect-policy": {
      "types": "./src/shared/redirect-policy.ts",
      "default": "./src/shared/redirect-policy.ts"
    },
    "./shared/protocol": {
      "types": "./src/shared/protocol.ts",
      "default": "./src/shared/protocol.ts"
    },
    "./client/provider": {
      "types": "./src/client/provider.tsx",
      "default": "./src/client/provider.tsx"
    },
    "./client/email-auth": {
      "types": "./src/client/email-auth.ts",
      "default": "./src/client/email-auth.ts"
    },
    "./client/email-otp-route": {
      "types": "./src/client/email-otp-route.ts",
      "default": "./src/client/email-otp-route.ts"
    },
    "./client/passkey": {
      "types": "./src/client/passkey.ts",
      "default": "./src/client/passkey.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./step-up-actions": {
      "types": "./src/shared/step-up-actions.ts",
      "default": "./src/shared/step-up-actions.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt src --write",
    "format:check": "oxfmt src --check",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.11",
    "@hominem/db": "workspace:*",
    "@hominem/utils": "workspace:*",
    "better-auth": "^1.6.11"
  },
  "devDependencies": {
    "react": "catalog:",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "react": "catalog:"
  }
}
