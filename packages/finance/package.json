{
  "name": "@hominem/finance-services",
  "version": "0.0.0",
  "description": "Financial services and transaction management",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "pnpm exec oxfmt ./src --write",
    "format:check": "pnpm exec oxfmt ./src --check",
    "lint": "pnpm exec oxlint ./src",
    "lint:fix": "pnpm exec oxlint ./src --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hominem/db": "workspace:*",
    "@hominem/utils": "workspace:*",
    "csv-parse": "^5.6.0",
    "effect": "^3.16.10",
    "kysely": "0.28.17",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.18.13",
    "typescript": "6.0.3",
    "vitest": "4.1.0"
  }
}
