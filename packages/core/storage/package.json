{
  "name": "@hominem/storage",
  "version": "0.0.0",
  "description": "Storage services and upload policy",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
