{
  "name": "@hominem/utils",
  "version": "0.0.0",
  "description": "Random utilities",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dates": {
      "types": "./src/dates.ts",
      "default": "./src/dates.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./src/http.ts"
    },
    "./time": {
      "types": "./src/time.ts",
      "default": "./src/time.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src"
  },
  "dependencies": {},
  "devDependencies": {}
}
