{
  "name": "@hominem/utils",
  "version": "0.0.0",
  "description": "Random utilities",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "default": "./src/storage/index.ts"
    },
    "./dates": {
      "types": "./src/dates.ts",
      "default": "./src/dates.ts"
    },
    "./images": {
      "types": "./src/images.ts",
      "default": "./src/images.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./src/http.ts"
    },
    "./logger": {
      "types": "./src/logger.ts",
      "default": "./src/logger.ts"
    },
    "./time": {
      "types": "./src/time.ts",
      "default": "./src/time.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.529.0",
    "@aws-sdk/s3-request-presigner": "^3.529.0"
  },
  "devDependencies": {}
}
