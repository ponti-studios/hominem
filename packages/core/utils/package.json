{
  "name": "@hominem/utils",
  "version": "0.0.0",
  "description": "Random utilities",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "default": "./src/storage/index.ts"
    },
    "./upload": {
      "types": "./src/upload/index.ts",
      "default": "./src/upload/index.ts"
    },
    "./consts": {
      "types": "./src/consts.ts",
      "default": "./src/consts.ts"
    },
    "./dates": {
      "types": "./src/dates.ts",
      "default": "./src/dates.ts"
    },
    "./headers": {
      "types": "./src/headers.ts",
      "default": "./src/headers.ts"
    },
    "./images": {
      "types": "./src/images.ts",
      "default": "./src/images.ts"
    },
    "./google": {
      "types": "./src/google.ts",
      "default": "./src/google.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./src/http.ts"
    },
    "./location": {
      "types": "./src/location/index.ts",
      "default": "./src/location/index.ts"
    },
    "./logger": {
      "types": "./src/logger.ts",
      "default": "./src/logger.ts"
    },
    "./client-logger": {
      "types": "./src/client-logger.ts",
      "default": "./src/client-logger.ts"
    },
    "./markdown": {
      "types": "./src/markdown/index.ts",
      "default": "./src/markdown/index.ts"
    },
    "./time": {
      "types": "./src/time.ts",
      "default": "./src/time.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.529.0",
    "@aws-sdk/s3-request-presigner": "^3.529.0",
    "@langchain/core": "^1.1.29",
    "@langchain/textsplitters": "^1.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.51.0",
    "date-fns": "^3.6.0",
    "langchain": "^1.2.28",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "typescript": "5.9.3"
  }
}
