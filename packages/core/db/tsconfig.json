{
  "extends": "../../../tsconfig.profiles/package-bundler.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./build",
    "tsBuildInfoFile": "../../../.cache/db.tsbuildinfo",
    "paths": {
      "@hakumi/db/schema/*": ["./src/migrations/schema.ts"],
      "@hakumi/db/services/*": ["./src/services/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    ".turbo",
    ".cache",
    "coverage",
    "*.tsbuildinfo"
  ]
}
