{
  "name": "@hominem/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    },
    "./test/*": {
      "types": "./src/test/*.ts",
      "default": "./src/test/*.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src",
    "kysely-codegen": "kysely-codegen --out-file ./src/types/database.ts"
  },
  "dependencies": {
    "@hominem/utils": "workspace:*",
    "csv-parser": "^3.2.0",
    "googleapis": "^170.0.0",
    "kysely": "^0.28.11",
    "openai": "4.83.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.5",
    "uuid": "^11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "dotenv": "^16.4.7",
    "kysely-codegen": "^0.15.0",
    "typescript": "5.9.3"
  }
}
