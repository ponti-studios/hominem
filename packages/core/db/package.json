{
  "name": "@hominem/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./build/index.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "build/index.d.ts"
      ],
      "schema/*": [
        "build/schema/*.d.ts"
      ],
      "types/*": [
        "build/schema/*.d.ts"
      ],
      "test/*": [
        "build/test/*.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    },
    "./schema/*": {
      "types": "./build/schema/*.d.ts",
      "import": "./build/schema/*.js",
      "default": "./build/schema/*.js"
    },
    "./types/*": {
      "types": "./build/schema/*.d.ts",
      "import": "./build/schema/*.js",
      "default": "./build/schema/*.js"
    },
    "./services/*": {
      "types": "./build/services/*.d.ts",
      "import": "./build/services/*.js",
      "default": "./build/services/*.js"
    },
    "./services/finance/*": {
      "types": "./build/services/finance/*.d.ts",
      "import": "./build/services/finance/*.js",
      "default": "./build/services/finance/*.js"
    },
    "./test/*": {
      "types": "./build/test/*.d.ts",
      "import": "./build/test/*.js",
      "default": "./build/test/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit",
    "kysely-codegen": "kysely-codegen --out-file ./src/types/database.ts",
    "goose:up": "goose -dir ./migrations postgres \"$DATABASE_URL\" up",
    "goose:down": "goose -dir ./migrations postgres \"$DATABASE_URL\" down",
    "goose:status": "goose -dir ./migrations postgres \"$DATABASE_URL\" status"
  },
  "dependencies": {
    "@hominem/utils": "workspace:*",
    "csv-parser": "^3.2.0",
    "googleapis": "^170.0.0",
    "openai": "4.83.0",
    "postgres": "^3.4.5",
    "uuid": "^11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "dotenv": "^16.4.7",
    "kysely-codegen": "^0.15.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
