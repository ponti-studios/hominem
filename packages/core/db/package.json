{
  "name": "@hominem/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    },
    "./test/*": {
      "types": "./src/test/*.ts",
      "default": "./src/test/*.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsgo --watch --preserveWatchOutput",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src",
    "kysely-codegen": "kysely-codegen --out-file ./src/types/database.ts"
  },
  "dependencies": {
    "kysely": "^0.28.11",
    "pg": "^8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "dotenv": "17.2.3",
    "kysely-codegen": "^0.20.0"
  }
}
