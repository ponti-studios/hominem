{
  "name": "@hominem/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    },
    "./services/finance/*": {
      "types": "./src/services/finance/*.ts",
      "default": "./src/services/finance/*.ts"
    },
    "./test/*": {
      "types": "./src/test/*.ts",
      "default": "./src/test/*.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit",
    "kysely-codegen": "kysely-codegen --out-file ./src/types/database.ts",
    "db:migrate": "make db-migrate && bun kysely-codegen",
    "db:rollback": "make db-rollback",
    "db:status": "make db-status"
  },
  "dependencies": {
    "@hominem/utils": "workspace:*",
    "csv-parser": "^3.2.0",
    "googleapis": "^170.0.0",
    "kysely": "^0.28.11",
    "pg": "^8.20.0",
    "openai": "4.83.0",
    "postgres": "^3.4.5",
    "uuid": "^11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "dotenv": "^16.4.7",
    "kysely-codegen": "^0.15.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
