      "react-native": "./src/components/layout/inline.native.tsx",
      "default": "./src/components/layout/inline.tsx"
    },
    "./page": {
      "react-native": "./src/components/layout/page.native.tsx",
      "default": "./src/components/layout/page.tsx"
    },
    "./input": "./src/components/ui/input.tsx",
    "./label": "./src/components/ui/label.tsx",
    "./textarea": "./src/components/ui/textarea.tsx",
    "./dialog": "./src/components/ui/dialog.tsx",
    "./dropdown": "./src/components/ui/dropdown-menu.tsx",
    "./card": {
      "react-native": "./src/components/ui/card.native.tsx",
      "default": "./src/components/ui/card.tsx"
    },
    "./loading": "./src/components/ui/loading.tsx",
    "./list": "./src/components/list.tsx",
    "./filters": "./src/components/filters/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./auth-server-routes": "./src/components/auth/web-auth-route-servers.ts",
