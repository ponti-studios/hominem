{
  "name": "@hominem/ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./button": {
      "react-native": "./src/components/ui/button.native.tsx",
      "default": "./src/components/ui/button.tsx"
    },
    "./heading": {
      "react-native": "./src/components/typography/heading.native.tsx",
      "default": "./src/components/typography/heading.tsx"
    },
    "./text": {
      "react-native": "./src/components/typography/text.native.tsx",
      "default": "./src/components/typography/text.tsx"
    },
    "./text-field": {
      "react-native": "./src/components/ui/text-field.native.tsx",
      "default": "./src/components/ui/text-field.tsx"
    },
    "./text-area": {
      "react-native": "./src/components/ui/text-area.native.tsx",
      "default": "./src/components/ui/text-area.tsx"
    },
    "./select-field": "./src/components/ui/select-field.tsx",
