  "scripts": {
    "format": "pnpm dlx oxfmt ./src",
    "lint": "pnpm dlx oxlint ./src",
    "typecheck": "tsgo --noEmit",
    "storybook": "storybook dev -p 6006",
    "test:storybook": "start-server-and-test storybook http://127.0.0.1:6006 test:storybook:run",
    "test:storybook:run": "test-storybook --url http://127.0.0.1:6006",
    "build:storybook": "storybook build"
