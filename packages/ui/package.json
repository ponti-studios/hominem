    "./components/ui/text-field.native": "./src/components/ui/text-field.native.tsx",
    "./components/ui/text-area.native": "./src/components/ui/text-area.native.tsx",
    "./components/ui/field.native": "./src/components/ui/field.native.tsx",
    "./components/typography/text.native": "./src/components/typography/text.native.tsx",
    "./components/typography/heading.native": "./src/components/typography/heading.native.tsx",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./styles/*": "./src/styles/*",
    "./ai-elements": "./src/components/ai-elements/index.ts",
    "./ai-elements/*": "./src/components/ai-elements/*.tsx",
    "./tokens": "./src/tokens/index.ts"
  },
  "scripts": {
    "format": "bunx oxfmt ./src",
    "lint": "bunx oxlint ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
