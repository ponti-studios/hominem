{
  "name": "@hominem/ai",
  "version": "0.0.0",
  "description": "AI and language model integration",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt src --write",
    "format:check": "oxfmt src --check",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix"
  },
  "dependencies": {
    "@hominem/utils": "workspace:*",
    "@openrouter/sdk": "^0.12.35",
    "@tanstack/ai": "^0.22.1",
    "@tanstack/ai-openrouter": "^0.9.8",
    "zod": "catalog:"
  },
  "devDependencies": {}
}
