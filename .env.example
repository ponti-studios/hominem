# =============================================================================
# DATABASE
# =============================================================================
# Start foundation first: cd ../foundation && just docker-up
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5434/hominem"
TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:4433/hominem-test"
REDIS_URL="redis://localhost:6379"

# =============================================================================
# PUBLIC URLS
# =============================================================================
API_URL="http://localhost:4040"
WEB_URL="http://localhost:4445"
NOTES_URL="http://localhost:4445"

# =============================================================================
# AUTH
# =============================================================================
COOKIE_SECRET=""
BETTER_AUTH_SECRET=""
AUTH_ISSUER="http://localhost:4040"
AUTH_AUDIENCE="hominem-api"
AUTH_PASSKEY_RP_ID="api.ponti.io"
AUTH_PASSKEY_ORIGIN="https://api.ponti.io"
AUTH_COOKIE_DOMAIN=""
AUTH_E2E_ENABLED="false"
AUTH_E2E_SECRET=""

# =============================================================================
# APPLE AUTH
# =============================================================================
APPLE_CLIENT_ID=""

# =============================================================================
# EMAIL
# =============================================================================
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME=""
SEND_EMAILS="false"

# =============================================================================
# FILE STORAGE
# =============================================================================
R2_ENDPOINT=""
R2_BUCKET_NAME="hominem-storage"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# =============================================================================
# OBSERVABILITY
# =============================================================================
#
# Local dev:
# 1. Start the dev stack: docker compose -f infra/compose/base.yml -f infra/compose/dev.yml up -d
# 2. Traces UI: http://localhost:16686
# 3. OTLP HTTP defaults to http://localhost:4318
#
# Preview / production:
# Traces + errors go to Sentry.
# See infra/railway/.env.preview.example and infra/railway/.env.production.example
# for deployed examples.
#
# To disable OTel entirely: OTEL_EXPORTER_OTLP_ENDPOINT=none

# OTLP endpoint. Use Sentry's OTLP endpoint in hosted environments.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Protocol: http/protobuf or grpc.
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Service name for the current process. Override per deployed service.
OTEL_SERVICE_NAME=hominem
OTEL_SERVICE_NAMESPACE=hominem
# Optional service version reported to the telemetry backend.
# OTEL_SERVICE_VERSION=
# Optional comma-separated key=value resource attributes.
# OTEL_RESOURCE_ATTRIBUTES=
OTEL_DEPLOYMENT_ENVIRONMENT=development
# Sampler: always_on, always_off, traceidratio, parentbased_traceidratio.
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_LOG_LEVEL=info

# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
