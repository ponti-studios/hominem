# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=""

# =============================================================================
# APPLE AUTH
# =============================================================================
APPLE_CLIENT_ID=""

# =============================================================================
# OBSERVABILITY (OpenTelemetry)
# =============================================================================
# These settings configure the app to send telemetry to your local observability
# stack. The stack runs independently at ~/.local/observability/
#
# Quick Start:
# 1. Start the observability stack: ~/.local/observability/observability.sh start
# 2. Add these variables to your .env
# 3. Run your app normally - telemetry flows automatically
#
# Access dashboards: http://localhost:3000 (admin/admin)

# OTLP Endpoint - where telemetry is sent
# This points to the OpenTelemetry Collector running in Docker
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Service identification (optional - services set their own names in code)
OTEL_SERVICE_NAME=hominem
OTEL_SERVICE_NAMESPACE=hominem
OTEL_DEPLOYMENT_ENVIRONMENT=development

# Sampling - 100% for local dev, reduce for production
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Log level for OTel SDK (debug, info, warn, error)
OTEL_LOG_LEVEL=info

# To disable telemetry entirely, uncomment:
# OTEL_TRACES_EXPORTER=none
# OTEL_METRICS_EXPORTER=none
