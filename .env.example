# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=""
REDIS_URL="redis://localhost:6379"

# =============================================================================
# PUBLIC URLS
# =============================================================================
API_URL="http://localhost:4040"
WEB_URL="http://localhost:4445"
NOTES_URL="http://localhost:4445"

# =============================================================================
# AUTH
# =============================================================================
COOKIE_SECRET=""
BETTER_AUTH_SECRET=""
AUTH_ISSUER="http://localhost:4040"
AUTH_AUDIENCE="hominem-api"
AUTH_PASSKEY_RP_ID="api.ponti.io"
AUTH_PASSKEY_ORIGIN="https://api.ponti.io"
AUTH_COOKIE_DOMAIN=""
AUTH_E2E_ENABLED="false"
AUTH_E2E_SECRET=""

# =============================================================================
# APPLE AUTH
# =============================================================================
APPLE_CLIENT_ID=""

# =============================================================================
# EMAIL
# =============================================================================
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME=""
SEND_EMAILS="false"

# =============================================================================
# FILE STORAGE
# =============================================================================
R2_ENDPOINT=""
R2_BUCKET_NAME="hominem-storage"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# =============================================================================
# OBSERVABILITY
# =============================================================================
#
# --- LOCAL DEV ---
# 1. Start the dev stack: docker compose -f infra/compose/base.yml -f infra/compose/dev.yml up -d
# 2. Traces UI: http://localhost:16686
# 3. OTLP HTTP defaults to http://localhost:4318 (default below)
#
# --- STAGING / PROD ---
# Traces + Errors → Sentry:  https://sentry.io
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://ingest.sentry.io/v1/traces
#   SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
#
# To disable OTel entirely: OTEL_EXPORTER_OTLP_ENDPOINT=none

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=hominem
OTEL_SERVICE_NAMESPACE=hominem
OTEL_DEPLOYMENT_ENVIRONMENT=development
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_LOG_LEVEL=info

# SENTRY_DSN=  # set in staging/prod only
