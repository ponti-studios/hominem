NODE_ENV="development"

# =============================================================================
# DATABASE
# =============================================================================
# Start foundation first: cd ../foundation && just docker-up
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5434/hominem"
REDIS_URL="redis://localhost:6379"

# =============================================================================
# PUBLIC URLS
# =============================================================================
API_URL="http://localhost:4040"
WEB_URL="http://localhost:4445"

# =============================================================================
# AUTH
# =============================================================================
BETTER_AUTH_SECRET=""
AUTH_PASSKEY_RP_ID="api.ponti.io"
AUTH_PASSKEY_ORIGIN="https://api.ponti.io"
AUTH_COOKIE_DOMAIN=""
AUTH_E2E_ENABLED="false"
AUTH_E2E_SECRET=""

# =============================================================================
# EMAIL
# =============================================================================
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME=""
SEND_EMAILS="false"

# =============================================================================
# AI
# =============================================================================
OPENROUTER_API_KEY=""
AI_MODEL="openai/gpt-4o-mini-2024-07-18"

# =============================================================================
# FILE STORAGE
# =============================================================================
R2_ENDPOINT=""
R2_BUCKET_NAME="hominem-storage"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# =============================================================================
# OBSERVABILITY
# =============================================================================
# To disable OTel entirely: OTEL_EXPORTER_OTLP_ENDPOINT=none
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_SERVICE_NAME="hominem"
SERVICE_NAME="hominem-api"
OTEL_SERVICE_NAMESPACE="hominem"
OTEL_DEPLOYMENT_ENVIRONMENT="development"
OTEL_TRACES_SAMPLER="parentbased_traceidratio"
OTEL_TRACES_SAMPLER_ARG="1.0"
OTEL_LOG_LEVEL="info"
SENTRY_DSN=""
